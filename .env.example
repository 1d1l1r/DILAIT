# Reference environment variables for DILIAT.
# The app does not auto-load .env files by itself.
# Use these values in your shell, launchd plist, or other startup configuration.

DILIAT_APP_NAME=Lights Hub
DILIAT_DEFAULT_TIMEZONE=Asia/Qyzylorda
# Usually leave DILIAT_DATABASE_URL unset and use the default <repo>/data/lights_hub.db.
# Example absolute override:
# DILIAT_DATABASE_URL=sqlite+aiosqlite:///ABSOLUTE/PATH/TO/DILAIT/data/lights_hub.db
DILIAT_SCHEDULER_POLL_SECONDS=1.0
DILIAT_BLE_SCAN_TIMEOUT_SECONDS=6.0
DILIAT_BLE_CONNECT_TIMEOUT_SECONDS=8.0

# Helper script defaults:
DILIAT_HOST=0.0.0.0
DILIAT_PORT=8000
